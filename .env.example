# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=esteemlearningcenter.com,www.esteemlearningcenter.com,127.0.0.1,localhost

# Database (PostgreSQL on Hetzner port 5433)
DATABASE_URL=postgres://esteemcbt_user:your-password@localhost:5433/esteemcbt

# Redis (use 127.0.0.1 for systemd, host.docker.internal for Docker)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://api-key:api-secret@cloud-name
DEFAULT_FILE_STORAGE=cloudinary_storage.storage.MediaCloudinaryStorage

# Email
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Paystack
PAYSTACK_MODE=live
PAYSTACK_TEST_SECRET_KEY=sk_test_xxx
PAYSTACK_TEST_PUBLIC_KEY=pk_test_xxx
PAYSTACK_LIVE_SECRET_KEY=sk_live_xxx
PAYSTACK_LIVE_PUBLIC_KEY=pk_live_xxx

# OpenAI
OPENAI_API_KEY=your-openai-key